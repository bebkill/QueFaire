---
import '../styles/global.css';
import sector from '../data/sector.json';

const { title = 'Que faire ?', description = `Toutes les sorties et activités en ${sector.name}, au même endroit.` } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="logo" href={base}>Que <em>faire</em> ?</a>
        <span class="sector-badge">{sector.name}</span>
        <nav class="header-nav">
          <a href={base}>Agenda</a>
          <a href={`${base}proposer/`}>Proposer une source</a>
          <a href={`${base}a-propos/`}>À propos</a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="wrap">
        <span>
          Que faire ? — {sector.event_count} événements agrégés depuis {sector.sources.length || 'nos'} sources locales.
        </span>
        <span>
          Données rafraîchies le {new Date(sector.generated_at).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' })}
          · <a href={`${base}a-propos/`}>Sources &amp; projet</a>
        </span>
      </div>
    </footer>
  </body>
</html>

---
import Base from '../layouts/Base.astro';
import EventCard from '../components/EventCard.astro';
import events from '../data/events.json';
import sector from '../data/sector.json';

const title = `Que faire en ${sector.name} ? Sorties, événements et activités`;
---

<Base title={title}>
  <section class="hero">
    <div class="wrap">
      <h1>Que faire <em>en {sector.name}</em>&nbsp;?</h1>
      <p class="sub">
        Concerts, randos, marchés, spectacles… {sector.event_count} idées de sorties
        collectées automatiquement auprès des communes et offices de tourisme.
      </p>

      <form class="searchbar" id="searchform" role="search">
        <input
          id="searchinput"
          type="search"
          placeholder="Ex : une sortie en famille ce week-end…"
          aria-label="Rechercher une activité"
          autocomplete="off"
        />
        <button type="submit">Chercher</button>
      </form>

      <p class="hints">
        Essayez :
        <button type="button" data-example>concert gratuit ce week-end</button> ·
        <button type="button" data-example>balade en famille à moins de 15 min</button> ·
        <button type="button" data-example>expo à Grenoble</button>
      </p>

      <div class="chips" id="chips">
        <button class="chip" data-chip="weekend" aria-pressed="false">📅 Ce week-end</button>
        <button class="chip" data-chip="today" aria-pressed="false">☀️ Aujourd'hui</button>
        <button class="chip" data-chip="famille" aria-pressed="false">👨‍👩‍👧 En famille</button>
        <button class="chip" data-chip="gratuit" aria-pressed="false">🆓 Gratuit</button>
        <button class="chip" data-chip="nearme" aria-pressed="false">📍 Près de moi</button>
        <button class="chip" id="mapchip" aria-pressed="false">🗺️ Carte</button>
      </div>
    </div>
  </section>

  <main class="wrap">
    <div class="toolbar">
      <span class="count" id="count">{events.length} événements</span>
      <button class="catfilter" id="catfilter" hidden title="Retirer ce filtre"></button>
      <label class="timefilter">
        ⏱ à moins de
        <select id="timelimit">
          <option value="">— (sans limite)</option>
          <option value="10">10 min</option>
          <option value="15">15 min</option>
          <option value="30">30 min</option>
          <option value="45">45 min</option>
          <option value="60">1 h</option>
        </select>
        <select id="timemode">
          <option value="car">en voiture</option>
          <option value="bike">en vélo</option>
          <option value="walk">à pied</option>
        </select>
      </label>
      <span class="geostate" id="geostate"></span>
      <button class="reset" id="reset" type="button">Tout réafficher</button>
    </div>

    <div id="mapwrap" hidden>
      <div id="map"></div>
      <p class="map-note">Temps de trajet estimés à vol d'oiseau corrigé — un calcul d'itinéraire précis arrive en roadmap.</p>
    </div>

    <div class="grid" id="grid">
      {events.map((event) => <EventCard event={event} />)}
    </div>

    <div class="empty" id="empty">
      <div class="big">🔍</div>
      <p>
        Rien ne correspond à cette recherche pour l'instant.<br />
        Élargissez les dates ou <button type="button" class="chip" id="empty-reset">réaffichez tout</button>.
      </p>
    </div>
  </main>
</Base>

<script>
  import { parseQuery, matches, distanceKm, travelMinutes, fold } from '../lib/nlsearch.js';
  import { CATEGORY_EMOJI } from '../lib/format.js';
  import sector from '../data/sector.json';

  const grid = document.getElementById('grid');
  const cards = Array.from(grid.querySelectorAll('.card'));
  const input = document.getElementById('searchinput');
  const form = document.getElementById('searchform');
  const countEl = document.getElementById('count');
  const geostate = document.getElementById('geostate');
  const resetBtn = document.getElementById('reset');
  const emptyEl = document.getElementById('empty');
  const chips = Array.from(document.querySelectorAll('[data-chip]'));
  const timeLimitEl = document.getElementById('timelimit');
  const timeModeEl = document.getElementById('timemode');
  const mapChip = document.getElementById('mapchip');
  const mapWrap = document.getElementById('mapwrap');

  let userPos = null; // {lat, lon}
  const state = { query: '', chips: new Set(), category: null };
  const MODE_LABELS = { walk: 'à pied', bike: 'en vélo', car: 'en voiture' };
  const catFilterEl = document.getElementById('catfilter');

  function setCategory(cat) {
    state.category = state.category === cat ? null : cat;
    if (state.category) {
      catFilterEl.hidden = false;
      catFilterEl.textContent = `${CATEGORY_EMOJI[state.category]} ${sector.categories[state.category]} ✕`;
    } else {
      catFilterEl.hidden = true;
    }
    apply();
  }
  catFilterEl.addEventListener('click', () => setCategory(state.category));

  const cardData = (card) => ({
    date: card.dataset.date,
    end: card.dataset.end,
    cat: card.dataset.cat,
    commune: card.dataset.commune,
    audience: card.dataset.audience,
    free: card.dataset.free,
    text: card.dataset.text,
    lat: parseFloat(card.dataset.lat),
    lon: parseFloat(card.dataset.lon),
  });

  function chipFilter(filter) {
    const now = new Date();
    const iso = (d) => new Date(d.getTime() - d.getTimezoneOffset() * 60000).toISOString().slice(0, 10);
    if (state.chips.has('today')) {
      filter.dateFrom = iso(now);
      filter.dateTo = iso(now);
    }
    if (state.chips.has('weekend')) {
      const sat = new Date(now);
      sat.setDate(sat.getDate() + ((6 - sat.getDay() + 7) % 7));
      const sun = new Date(sat);
      sun.setDate(sat.getDate() + 1);
      filter.dateFrom = iso(now.getDay() === 5 ? now : sat);
      filter.dateTo = iso(sun);
    }
    if (state.chips.has('famille') && !filter.audience.includes('famille')) {
      filter.audience.push('famille');
    }
    if (state.chips.has('gratuit')) filter.free = true;
    if (state.chips.has('nearme')) filter.nearMe = true;
    // Filtre catégorie posé depuis un pétale de cluster : il prime.
    if (state.category) filter.categories = [state.category];
    return filter;
  }

  function requestGeoloc(cb) {
    if (userPos) return cb();
    if (!navigator.geolocation) {
      geostate.textContent = 'Géolocalisation non disponible sur ce navigateur.';
      return cb();
    }
    geostate.textContent = 'Localisation en cours…';
    navigator.geolocation.getCurrentPosition(
      (pos) => {
        userPos = { lat: pos.coords.latitude, lon: pos.coords.longitude };
        geostate.textContent = '';
        cb();
      },
      () => {
        geostate.textContent = `Position refusée — tri depuis le centre ${sector.name}.`;
        userPos = { lat: sector.center.lat, lon: sector.center.lon };
        cb();
      },
      { timeout: 8000 }
    );
  }

  function currentFilter() {
    const filter = chipFilter(parseQuery(state.query, sector.communes));
    // Les sélecteurs de la barre d'outils complètent la requête (elle prime).
    if (filter.maxMinutes == null && timeLimitEl.value) {
      filter.maxMinutes = parseInt(timeLimitEl.value, 10);
    }
    if (!filter.modeExplicit) filter.mode = timeModeEl.value;
    return filter;
  }

  function apply() {
    const filter = currentFilter();
    const needsGeo = filter.nearMe || filter.maxMinutes != null;

    if (needsGeo && !userPos) {
      requestGeoloc(apply);
      return;
    }

    let shown = 0;
    const visible = [];
    for (const card of cards) {
      const data = cardData(card);
      let ok = matches(data, filter);
      let dist = null;
      let minutes = null;
      if (ok && needsGeo && userPos && !Number.isNaN(data.lat)) {
        dist = distanceKm(userPos.lat, userPos.lon, data.lat, data.lon);
        minutes = travelMinutes(dist, filter.mode);
        if (filter.maxMinutes != null && minutes > filter.maxMinutes) ok = false;
      }
      card.classList.toggle('hidden', !ok);
      const distEl = card.querySelector('[data-role="distance"]');
      if (ok) {
        shown += 1;
        distEl.textContent =
          filter.maxMinutes != null && minutes != null
            ? `~${Math.round(minutes)} min ${MODE_LABELS[filter.mode]}`
            : dist != null
              ? `~${Math.round(dist)} km`
              : '';
        visible.push({ card, dist, date: data.date, data });
      } else {
        distEl.textContent = '';
      }
    }

    // Tri : proximité si géolocalisé, sinon date.
    visible.sort((a, b) =>
      needsGeo && a.dist != null && b.dist != null
        ? a.dist - b.dist || a.date.localeCompare(b.date)
        : a.date.localeCompare(b.date)
    );
    for (const { card } of visible) grid.appendChild(card);

    countEl.textContent = shown === 1 ? '1 événement' : `${shown} événements`;
    emptyEl.classList.toggle('visible', shown === 0);
    grid.style.display = shown === 0 ? 'none' : '';
    const isFiltered =
      state.query.trim() !== '' || state.chips.size > 0 || timeLimitEl.value !== '' ||
      state.category != null;
    resetBtn.classList.toggle('visible', isFiltered);

    lastVisible = visible;
    updateMap(visible, true);
  }

  // ---------------- Carte (Leaflet, chargé à la demande) ----------------
  let leaflet = null; // { map, layer, L, userMarker }
  let lastVisible = [];

  async function initMap() {
    const L = (await import('leaflet')).default;
    await import('leaflet/dist/leaflet.css');
    const map = L.map('map', { scrollWheelZoom: false }).setView(
      [sector.center.lat, sector.center.lon], 9
    );
    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 18,
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    }).addTo(map);
    leaflet = { L, map, layer: L.layerGroup().addTo(map), userMarker: null };
    // Le zoom change la granularité des clusters — sans recadrer la vue.
    map.on('zoomend', () => updateMap(lastVisible, false));
  }

  function catColor(cat) {
    return (
      getComputedStyle(document.documentElement).getPropertyValue(`--c-${cat}`).trim() ||
      '#868e96'
    );
  }

  /** Regroupe les points par proximité à l'écran (~70 px au zoom courant). */
  function buildClusters(items, map) {
    const RADIUS = 70;
    const zoom = map.getZoom();
    const clusters = [];
    for (const it of items) {
      const pt = map.project([it.lat, it.lon], zoom);
      let best = null;
      let bestD = Infinity;
      for (const cl of clusters) {
        const d = pt.distanceTo(cl.pt);
        if (d < RADIUS && d < bestD) { best = cl; bestD = d; }
      }
      if (best) {
        best.items.push(it);
        best.lat += (it.lat - best.lat) / best.items.length; // centroïde glissant
        best.lon += (it.lon - best.lon) / best.items.length;
        best.pt = map.project([best.lat, best.lon], zoom);
      } else {
        clusters.push({ lat: it.lat, lon: it.lon, pt, items: [it] });
      }
    }
    return clusters;
  }

  /** Fleur SVG : total au centre, pétales émoji cliquables (top 5 + ✚). */
  function flowerSVG(petals, total, size) {
    const c = size / 2, rC = size * 0.21, rOrbit = size * 0.335;
    let svg = '';
    petals.forEach((cat, i) => {
      const a = -Math.PI / 2 + i * ((Math.PI * 2) / petals.length);
      const pr = size * 0.085 + (cat.n / total) * size * 0.13;
      const x = c + rOrbit * Math.cos(a), y = c + rOrbit * Math.sin(a);
      const active = cat.k === state.category;
      const action = cat.k === 'more' ? 'data-center=""' : `data-cat="${cat.k}"`;
      svg += `<g ${action} cursor="pointer">
        <title>${cat.label} : ${cat.n}${cat.k === 'more' ? ' — cliquer pour zoomer' : ' — cliquer pour filtrer'}</title>
        <circle cx="${x}" cy="${y}" r="${pr}" fill="${active ? cat.color : '#fff'}" stroke="${cat.color}" stroke-width="${size * (active ? 0.03 : 0.018)}"/>
        <text x="${x}" y="${y - 1}" text-anchor="middle" dominant-baseline="central" font-size="${pr * 0.95}">${cat.emoji}</text>
        <circle cx="${x + pr * 0.78}" cy="${y - pr * 0.78}" r="${size * 0.052}" fill="${cat.color}"/>
        <text x="${x + pr * 0.78}" y="${y - pr * 0.78}" text-anchor="middle" dominant-baseline="central" font-size="${size * 0.055}" font-weight="700" fill="#fff">${cat.n}</text>
      </g>`;
    });
    return `<svg width="${size}" height="${size}" viewBox="0 0 ${size} ${size}" style="overflow:visible; filter:drop-shadow(0 2px 6px rgba(0,0,0,.3))">
      ${svg}
      <g data-center="" cursor="pointer">
        <title>Zoomer sur cette zone</title>
        <circle cx="${c}" cy="${c}" r="${rC}" fill="#23211c"/>
        <text x="${c}" y="${c - 2}" text-anchor="middle" dominant-baseline="central" font-weight="800" font-size="${rC * 0.8}" fill="#fff">${total}</text>
        <text x="${c}" y="${c + rC * 0.55}" text-anchor="middle" font-size="${rC * 0.3}" fill="#d5cfc2">activités</text>
      </g>
    </svg>`;
  }

  function zoomInto(cluster) {
    const { L, map } = leaflet;
    const bounds = L.latLngBounds(cluster.items.map((i) => [i.lat, i.lon]));
    const spread = bounds.getNorthEast().distanceTo(bounds.getSouthWest());
    if (spread < 100 || map.getZoom() >= 15) {
      // Tout au même endroit (géocodage à la commune) : liste plutôt que zoom.
      const links = cluster.items
        .slice(0, 12)
        .map((i) => `<a href="${i.href}">${i.title}</a>`)
        .join('<br>');
      const more = cluster.items.length > 12 ? `<br>… et ${cluster.items.length - 12} autres` : '';
      L.popup({ maxHeight: 220 }).setLatLng([cluster.lat, cluster.lon]).setContent(links + more).openOn(map);
    } else {
      map.fitBounds(bounds, { padding: [50, 50] });
    }
  }

  function addFlower(cluster) {
    const { L, map, layer } = leaflet;
    const counts = {};
    for (const it of cluster.items) counts[it.cat] = (counts[it.cat] || 0) + 1;
    const entries = Object.entries(counts)
      .map(([k, n]) => ({ k, n, emoji: CATEGORY_EMOJI[k] || '📌', color: catColor(k), label: sector.categories[k] || k }))
      .sort((a, b) => b.n - a.n);
    const petals = entries.slice(0, 5);
    const rest = entries.slice(5);
    if (rest.length) {
      petals.push({ k: 'more', n: rest.reduce((s, e) => s + e.n, 0), emoji: '✚', color: '#868e96', label: 'Autres thèmes' });
    }
    const total = cluster.items.length;
    const size = Math.max(88, Math.min(150, 70 + total * 2));
    const icon = L.divIcon({
      className: 'flower-icon',
      html: flowerSVG(petals, total, size),
      iconSize: [size, size],
      iconAnchor: [size / 2, size / 2],
    });
    const marker = L.marker([cluster.lat, cluster.lon], { icon }).addTo(layer);
    const el = marker.getElement();
    for (const g of el.querySelectorAll('[data-cat]')) {
      g.addEventListener('click', (e) => { e.stopPropagation(); setCategory(g.dataset.cat); });
    }
    for (const g of el.querySelectorAll('[data-center]')) {
      g.addEventListener('click', (e) => { e.stopPropagation(); zoomInto(cluster); });
    }
  }

  function updateMap(visible, fitView) {
    if (!leaflet || mapWrap.hidden) return;
    const { L, map, layer } = leaflet;
    layer.clearLayers();

    const items = [];
    for (const { card, data } of visible) {
      if (Number.isNaN(data.lat)) continue;
      items.push({
        lat: data.lat, lon: data.lon, cat: data.cat, commune: data.commune,
        title: card.querySelector('h3').textContent,
        href: card.getAttribute('href'),
        color: getComputedStyle(card.querySelector('.card-top')).borderBottomColor,
      });
    }

    const points = [];
    for (const cluster of buildClusters(items, map)) {
      if (cluster.items.length >= 3) {
        addFlower(cluster);
        points.push([cluster.lat, cluster.lon]);
      } else {
        cluster.items.forEach((it, n) => {
          let { lat, lon } = it;
          if (n > 0) { lat += 0.0035; } // 2 points superposés : léger décalage
          L.circleMarker([lat, lon], {
            radius: 8, color: it.color, fillColor: it.color, fillOpacity: 0.75, weight: 2,
          })
            .bindPopup(`<strong>${it.title}</strong><br>${it.commune || ''}<br><a href="${it.href}">Voir la fiche →</a>`)
            .addTo(layer);
          points.push([lat, lon]);
        });
      }
    }

    if (userPos) {
      if (leaflet.userMarker) leaflet.userMarker.remove();
      leaflet.userMarker = L.circleMarker([userPos.lat, userPos.lon], {
        radius: 7, color: '#1c7ed6', fillColor: '#1c7ed6', fillOpacity: 1, weight: 3,
      }).bindPopup('Vous êtes ici').addTo(map);
      points.push([userPos.lat, userPos.lon]);
    }
    if (fitView && points.length) map.fitBounds(points, { padding: [40, 40], maxZoom: 13 });
  }

  mapChip.addEventListener('click', async () => {
    mapWrap.hidden = !mapWrap.hidden;
    mapChip.setAttribute('aria-pressed', String(!mapWrap.hidden));
    if (!mapWrap.hidden) {
      if (!leaflet) await initMap();
      leaflet.map.invalidateSize();
      apply();
    }
  });

  timeLimitEl.addEventListener('change', apply);
  timeModeEl.addEventListener('change', apply);

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    state.query = input.value;
    // La requête peut activer chips et sélecteurs implicitement (retour visuel).
    const parsed = parseQuery(state.query, sector.communes);
    syncChips(parsed);
    if (parsed.maxMinutes != null) {
      const opt = Array.from(timeLimitEl.options).find((o) => o.value === String(parsed.maxMinutes));
      timeLimitEl.value = opt ? opt.value : '';
    }
    if (parsed.modeExplicit) timeModeEl.value = parsed.mode;
    apply();
  });

  input.addEventListener('input', () => {
    if (input.value === '') {
      state.query = '';
      apply();
    }
  });

  function syncChips(parsed) {
    for (const chip of chips) {
      const key = chip.dataset.chip;
      const active =
        state.chips.has(key) ||
        (key === 'gratuit' && parsed.free === true) ||
        (key === 'famille' && parsed.audience.includes('famille')) ||
        (key === 'nearme' && parsed.nearMe);
      chip.setAttribute('aria-pressed', String(active));
    }
  }

  for (const chip of chips) {
    chip.addEventListener('click', () => {
      const key = chip.dataset.chip;
      if (state.chips.has(key)) state.chips.delete(key);
      else state.chips.add(key);
      chip.setAttribute('aria-pressed', String(state.chips.has(key)));
      apply();
    });
  }

  function resetAll() {
    state.query = '';
    state.chips.clear();
    state.category = null;
    catFilterEl.hidden = true;
    input.value = '';
    timeLimitEl.value = '';
    for (const chip of chips) chip.setAttribute('aria-pressed', 'false');
    apply();
  }
  resetBtn.addEventListener('click', resetAll);
  document.getElementById('empty-reset').addEventListener('click', resetAll);

  for (const btn of document.querySelectorAll('[data-example]')) {
    btn.addEventListener('click', () => {
      input.value = btn.textContent;
      form.requestSubmit();
    });
  }
</script>

---
import Base from '../../layouts/Base.astro';
import events from '../../data/events.json';
import sector from '../../data/sector.json';
import { CATEGORY_EMOJI, formatWhen, priceLabel } from '../../lib/format.js';

export function getStaticPaths() {
  return events.map((event) => ({ params: { id: event.id }, props: { event } }));
}

const { event } = Astro.props;
const base = import.meta.env.BASE_URL;
const price = priceLabel(event);
const source = sector.sources.find((s) => s.id === event.source_id);
const audienceLabels = {
  famille: 'En famille', enfants: 'Enfants', ados: 'Ados',
  adultes: 'Adultes', seniors: 'Seniors', tous: 'Tout public',
};
---

<Base title={`${event.title} — Que faire en ${sector.name} ?`} description={event.description.slice(0, 150)}>
  <section class="detail-hero" style={`--cat: var(--c-${event.category})`}>
    <div class="wrap">
      <span class="cat-label">{CATEGORY_EMOJI[event.category]} {sector.categories[event.category]}</span>
      <h1>{event.title}</h1>
      <p class="when">📅 {formatWhen(event.start, event.end)}</p>
    </div>
  </section>

  <main class="wrap">
    <div class="detail-cols">
      <div>
        {event.tldr && <p class="detail-tldr">💡 En clair : {event.tldr}</p>}
        <p class="detail-desc">{event.description || 'Pas de description pour cet événement — consultez la source pour en savoir plus.'}</p>
        <a class="backlink" href={base}>← Retour à l'agenda</a>
      </div>

      <aside class="infobox">
        {event.commune && (
          <div class="row">
            <b>Lieu</b>
            📍 {event.commune}{event.address && ` — ${event.address}`}
          </div>
        )}
        {price && (
          <div class="row">
            <b>Tarif</b>
            {price}
          </div>
        )}
        {event.audience.length > 0 && (
          <div class="row">
            <b>Public</b>
            {event.audience.map((a) => audienceLabels[a] || a).join(', ')}
          </div>
        )}
        <div class="row">
          <b>Source</b>
          {source ? source.name : event.source_id === 'demo' ? 'Données de démonstration' : event.source_id}
          {event.url && (
            <a class="src" href={event.url} target="_blank" rel="noopener">
              Voir sur le site source ↗
            </a>
          )}
        </div>
      </aside>
    </div>
  </main>
</Base>
